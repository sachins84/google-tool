# Server
PORT=5011
NODE_ENV=development
SESSION_SECRET=change-me-to-a-long-random-string

# Admin bootstrap (created on first run if no users exist)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Google Ads API (via AdYogi proxy for token exchange)
ADYOGI_TOKEN_URL=https://googleadsapi.adyogi.com/access_token
GOOGLE_ADS_REFRESH_TOKEN=your-refresh-token-here
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token-here
GOOGLE_ADS_API_VERSION=v21

# Redshift (placeholder — set when ready to enable post-RTO live mode)
REDSHIFT_HOST=
REDSHIFT_PORT=5439
REDSHIFT_DB=
REDSHIFT_USER=
REDSHIFT_PASSWORD=

# YouTube uploader (separate from Google Ads token — uses standard Google OAuth)
# 1. Create an OAuth client (Web application) in your GCP project with redirect
#    http://localhost:8765/callback and enable: YouTube Data v3, Drive, Sheets.
# 2. Paste client ID + secret below.
# 3. Run: yarn workspace @google-ads-tool/server tsx scripts/yt-oauth.ts
#    once per YouTube channel you want to upload to.
# 4. Paste the returned refresh tokens below.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Default channel (key = "default")
YT_REFRESH_TOKEN=
YT_DEFAULT_CHANNEL_LABEL=
# Additional channels — key is the lowercased suffix
# YT_REFRESH_TOKEN_MANMATTERS=
# YT_REFRESH_TOKEN_LITTLEJOYS=
